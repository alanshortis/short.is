---
import { SchemeToggle } from './';
import { earliestPhotographyYear } from '../content/photography';

const thisYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__links">
    <p>&copy; {earliestPhotographyYear}-{thisYear}</p>
    <a href="/writing.xml">RSS</a>
    <a href="https://bsky.app/profile/short.is" target="_blank" rel="noopener noreferrer">Bluesky</a>
  </div>
  <SchemeToggle />
</footer>

<style lang="scss">
  @use '../styles/mixins' as *;
  .footer {
    align-items: flex-end;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space--large);
    justify-content: space-between;
    padding-block: var(--space--large);
    padding-inline: var(--space);
    @include fixed-width;
    &__links {
      display: flex;
      gap: var(--space);
      @include label;
    }
  }
</style>
