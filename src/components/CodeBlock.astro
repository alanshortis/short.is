<code-block class="code-block">
  <header class="code-block__header">
    <svg
      width="32"
      height="8"
      viewBox="0 0 40 8"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden
    >
      <circle cx="4" cy="4" r="4"></circle>
      <circle cx="20" cy="4" r="4"></circle>
      <circle cx="36" cy="4" r="4"></circle>
    </svg>
    <span>
      <button class="code-block__copy js-copy" type="button">Copy</button>
      <span class="vh js-copy-status" aria-live="polite" aria-atomic="true" aria-relevant="text"></span>
    </span>
  </header>
  <pre class="code-block__content js-content"><slot /></pre>
</code-block>

<script>
  class CodeBlock extends HTMLElement {
    private abortController: AbortController;

    constructor() {
      super();
      this.abortController = new AbortController();
    }

    connectedCallback() {
      const copyButton = this.querySelector('.js-copy')! as HTMLButtonElement;
      const statusEl = this.querySelector('.js-copy-status')!;
      const codeBlock = this.querySelector('.js-content')!;

      copyButton.addEventListener(
        'click',
        async () => {
          try {
            await navigator.clipboard.writeText(codeBlock.textContent || '');
            const originalLabel = copyButton.textContent;
            copyButton.textContent = 'Copied';
            statusEl.textContent = 'Code copied to clipboard';
            setTimeout(() => {
              copyButton.textContent = originalLabel;
              statusEl.textContent = '';
            }, 2000);
          } catch {
            statusEl.textContent = 'Copy failed';
          }
        },
        { signal: this.abortController.signal }
      );
    }

    disconnectedCallback() {
      this.abortController.abort();
    }
  }

  customElements.define('code-block', CodeBlock);
</script>

<style lang="scss">
  @use '../styles/mixins' as *;

  .code-block {
    border: 1px solid var(--divider);
    border-radius: 0.5em 0.5em var(--radius) var(--radius);
    display: block;
    margin: var(--step-2) 0;
    &__copy {
      @include label;
      font-size: var(--step--2);
      margin-inline-start: auto;
      &:focus-visible {
        @include focus-outline;
      }
    }
    &__header {
      display: flex;
      align-items: center;
      gap: var(--step--2);
      justify-content: space-between;
      padding-inline: var(--step--2);
    }
    &__content {
      color: var(--code);
      font-size: var(--step--1);
      line-height: 1;
      overflow-x: auto;
      padding: var(--step--2);
      position: relative;
      font-family: monospace;
      line-height: 1.5;
    }
  }
</style>
