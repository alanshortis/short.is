---
const S3 = import.meta.env.S3;
const lightboxShellMs = 200;
const lightboxImgCrossfadeMs = 300;
---

<photo-lightbox
  data-s3={S3}
  data-shell-ms={lightboxShellMs}
  data-crossfade-ms={lightboxImgCrossfadeMs}
>
  <slot />
  <dialog class="lightbox" aria-label="Photo viewer">
    <nav class="lightbox__nav">
      <button type="button" class="lightbox__control" data-action="prev" disabled>Previous</button>
      <button type="button" class="lightbox__control" data-action="close">Close</button>
      <button type="button" class="lightbox__control" data-action="next" disabled>Next</button>
    </nav>
    <img class="lightbox__img" alt="" />
  </dialog>
</photo-lightbox>

<script>
  class PhotoLightbox extends HTMLElement {
    private static readonly TRANSITION_SLACK_MS = 80;

    private lifetimeAbort = new AbortController();
    private dialog: HTMLDialogElement;
    private img: HTMLImageElement;
    private closeBtn: HTMLButtonElement;
    private prevBtn: HTMLButtonElement;
    private nextBtn: HTMLButtonElement;
    private photos: Array<{ name: string; ratio: string; alt: string }> = [];
    private currentIndex = -1;
    private s3 = this.dataset.s3;

    private crossfadeFallbackTimer: number | null = null;
    private crossfadeAbort = new AbortController();
    private shellFallbackTimer: number | null = null;
    private shellAbort = new AbortController();

    private preloadScope = '';

    constructor() {
      super();
      this.dialog = this.querySelector('dialog')!;
      this.img = this.dialog.querySelector('img')!;
      this.closeBtn = this.dialog.querySelector('[data-action="close"]')!;
      this.prevBtn = this.dialog.querySelector('[data-action="prev"]')!;
      this.nextBtn = this.dialog.querySelector('[data-action="next"]')!;
    }

    private resetCrossfadeTransition() {
      if (this.crossfadeFallbackTimer !== null) {
        window.clearTimeout(this.crossfadeFallbackTimer);
        this.crossfadeFallbackTimer = null;
      }
      this.crossfadeAbort.abort();
      this.crossfadeAbort = new AbortController();
    }

    private resetShellTransition() {
      if (this.shellFallbackTimer !== null) {
        window.clearTimeout(this.shellFallbackTimer);
        this.shellFallbackTimer = null;
      }
      this.shellAbort.abort();
      this.shellAbort = new AbortController();
    }

    private shouldAnimate(): boolean {
      return window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
    }

    private applyPhoto(photo: { name: string; ratio: string; alt: string }) {
      this.img.src = `${this.s3}${photo.name}-2x.avif`;
      this.img.srcset = `${this.s3}${photo.name}-4x.avif 2x`;
      this.img.alt = photo.alt;
      this.img.style.aspectRatio = photo.ratio;
    }

    private clearPhotoPresentation() {
      this.img.src = '';
      this.img.srcset = '';
      this.img.alt = '';
      this.img.style.aspectRatio = '';
      this.img.style.opacity = '';
    }

    private revealPhotoOpaque() {
      void this.img.decode().finally(() => {
        if (!this.isConnected) return;
        this.img.style.opacity = '1';
      });
    }

    private preloadSuffix(): '2x' | '4x' {
      const c = (navigator as Navigator & { connection?: { saveData?: boolean; effectiveType?: string } })
        .connection;
      if (!c) return '4x';
      if (c.saveData) return '2x';
      if (c.effectiveType === 'slow-2g' || c.effectiveType === '2g') return '2x';
      return '4x';
    }

    private open(index: number) {
      if (index < 0 || index >= this.photos.length) return;

      const photo = this.photos[index];
      const alreadyOpen = this.dialog.open;

      if (this.dialog.classList.contains('closing')) {
        this.resetShellTransition();
        this.dialog.classList.remove('closing');
      }

      this.currentIndex = index;
      this.syncUiState();
      history.replaceState(null, '', `#${photo.name}`);

      if (!this.dialog.open) {
        document.documentElement.style.overflow = 'hidden';
        this.dialog.showModal();
      }

      if (!alreadyOpen) {
        this.applyPhoto(photo);
        this.img.style.opacity = '1';
        return;
      }

      if (!this.shouldAnimate()) {
        this.applyPhoto(photo);
        this.revealPhotoOpaque();
        return;
      }

      this.resetCrossfadeTransition();
      this.img.style.opacity = '0';

      let ran = false;
      const afterFadeOut = () => {
        if (ran) return;
        ran = true;
        this.resetCrossfadeTransition();
        this.applyPhoto(photo);
        this.revealPhotoOpaque();
      };

      const onImgOpacityEnd = (event: TransitionEvent) => {
        if (event.target !== this.img || event.propertyName !== 'opacity') return;
        afterFadeOut();
      };

      const fadeMs = Number(this.dataset.crossfadeMs) || 300;
      this.crossfadeFallbackTimer = window.setTimeout(
        afterFadeOut,
        fadeMs + PhotoLightbox.TRANSITION_SLACK_MS
      );
      this.img.addEventListener('transitionend', onImgOpacityEnd, { signal: this.crossfadeAbort.signal });
    }

    private syncUiState() {
      this.prevBtn.disabled = this.currentIndex <= 0;
      this.nextBtn.disabled = this.currentIndex >= this.photos.length - 1;

      if (
        document.activeElement === this.closeBtn ||
        document.activeElement === this.prevBtn ||
        document.activeElement === this.nextBtn
      ) {
        this.dialog.focus();
      }

      if (this.currentIndex > 0) this.preload(this.currentIndex - 1);
      if (this.currentIndex < this.photos.length - 1) this.preload(this.currentIndex + 1);
    }

    private prev() {
      if (this.currentIndex > 0) this.open(this.currentIndex - 1);
    }

    private next() {
      if (this.currentIndex < this.photos.length - 1) this.open(this.currentIndex + 1);
    }

    private openFromHash() {
      const hash = location.hash.slice(1);
      if (!hash) {
        if (this.dialog.open) this.close();
        return;
      }
      const index = this.photos.findIndex(p => p.name === hash);
      if (index === -1) {
        if (this.dialog.open) this.close();
        history.replaceState(null, '', location.pathname);
        return;
      }
      this.open(index);
    }

    private close() {
      if (!this.dialog.open) return;
      if (this.dialog.classList.contains('closing')) return;

      this.resetCrossfadeTransition();

      const finalizeClose = () => {
        this.resetShellTransition();
        this.dialog.classList.remove('closing');
        document.documentElement.style.overflow = '';
        this.dialog.close();
        this.clearPhotoPresentation();
        history.replaceState(null, '', location.pathname);
      };

      if (!this.shouldAnimate()) {
        finalizeClose();
        return;
      }

      let ran = false;
      const afterShellFade = () => {
        if (ran) return;
        ran = true;
        finalizeClose();
      };

      this.resetShellTransition();
      this.dialog.classList.add('closing');

      const onShellOpacityEnd = (event: TransitionEvent) => {
        if (event.target !== this.dialog || event.propertyName !== 'opacity') return;
        afterShellFade();
      };

      const shellMs = Number(this.dataset.shellMs) || 200;
      this.shellFallbackTimer = window.setTimeout(
        afterShellFade,
        shellMs + PhotoLightbox.TRANSITION_SLACK_MS
      );
      this.dialog.addEventListener('transitionend', onShellOpacityEnd, { signal: this.shellAbort.signal });
    }

    private preload(index: number) {
      const photo = this.photos[index];
      const id = `preload-${this.preloadScope}-${photo.name}`;
      if (document.getElementById(id)) return;

      const link = document.createElement('link');
      link.id = id;
      link.rel = 'preload';
      link.as = 'image';
      link.type = 'image/avif';
      link.href = `${this.s3}${photo.name}-${this.preloadSuffix()}.avif`;
      document.head.appendChild(link);
    }

    connectedCallback() {
      this.lifetimeAbort.abort();
      this.lifetimeAbort = new AbortController();
      const { signal } = this.lifetimeAbort;

      if (!this.preloadScope) {
        this.preloadScope = typeof crypto !== 'undefined' && 'randomUUID' in crypto ? crypto.randomUUID() : String(Date.now());
      }

      const anchors = Array.from(this.querySelectorAll<HTMLAnchorElement>('a[data-photo-name]'));

      this.photos = anchors.map(a => ({
        name: a.dataset.photoName!,
        ratio: a.dataset.photoRatio!,
        alt: a.dataset.photoAlt!,
      }));

      anchors.forEach((a, i) => {
        a.addEventListener(
          'click',
          (event: MouseEvent) => {
            event.preventDefault();
            this.open(i);
          },
          { signal }
        );
        a.addEventListener('pointerenter', () => this.preload(i), { signal, once: true });
      });

      this.dialog.addEventListener(
        'cancel',
        (event: Event) => {
          event.preventDefault();
          this.close();
        },
        { signal }
      );

      this.dialog.addEventListener(
        'click',
        (event: MouseEvent) => {
          if (event.target === this.dialog) this.close();
        },
        { signal }
      );

      this.closeBtn.addEventListener('click', () => this.close(), { signal });
      this.prevBtn.addEventListener('click', () => this.prev(), { signal });
      this.nextBtn.addEventListener('click', () => this.next(), { signal });

      this.dialog.addEventListener(
        'keydown',
        (event: KeyboardEvent) => {
          if (event.key === 'ArrowLeft' || event.key === 'ArrowRight') {
            event.preventDefault();
            if (event.key === 'ArrowLeft') this.prev();
            else this.next();
          }
        },
        { signal }
      );

      this.openFromHash();
      window.addEventListener('hashchange', () => this.openFromHash(), { signal });
    }

    disconnectedCallback() {
      this.resetCrossfadeTransition();
      this.resetShellTransition();
      this.lifetimeAbort.abort();
      this.dialog.classList.remove('closing');
      document.documentElement.style.overflow = '';
      if (this.dialog.open) {
        this.dialog.close();
        this.clearPhotoPresentation();
      }
    }
  }

  customElements.define('photo-lightbox', PhotoLightbox);
</script>

<style lang="scss" define:vars={{ lightboxShellMs, lightboxImgCrossfadeMs }}>
  @use '../styles/mixins' as *;

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.6;
    }
  }

  .lightbox {
    border: 0;
    height: 100dvh;
    inset: 0;
    margin: 0;
    max-height: none;
    max-width: none;
    outline: none;
    padding: 0;
    opacity: 0;
    position: fixed;
    width: 100dvw;
    @include backdrop;
    &[open] {
      align-items: center;
      display: flex;
      justify-content: center;
      opacity: 1;
      @starting-style {
        opacity: 0;
      }
    }
    &.closing {
      opacity: 0;
    }
    &::backdrop {
      display: none;
    }
    &::after {
      aspect-ratio: 1;
      background: var(--foreground);
      border-radius: 50%;
      content: '';
      block-size: var(--step--2);
      opacity: 0.35;
      position: absolute;
      inset-block-start: 50%;
      inset-inline-start: 50%;
      translate: -50% -50%;
    }

    @include should-animate {
      transition: opacity calc(var(--lightboxShellMs) * 1ms) ease;

      &::after {
        opacity: 0.2;
        animation: pulse 1s ease-in-out infinite;
      }
    }

    &__img {
      border-radius: calc(var(--radius) * 2);
      display: block;
      max-width: min(1440px, calc(100dvw - var(--space) * 4));
      max-height: min(1440px, calc(100dvh - var(--space) * 4));
      position: relative;
      z-index: 1;

      @include should-animate {
        transition: opacity calc(var(--lightboxImgCrossfadeMs) * 1ms) ease;
      }
      @include medium {
        border-radius: 0;
        max-width: 100dvw;
        max-height: 100dvh;
      }
    }
    &__nav {
      align-items: center;
      block-size: var(--space--large);
      border-radius: var(--space--large);
      display: flex;
      gap: var(--space--large);
      padding-inline: var(--space);
      position: absolute;
      inset-block-end: var(--space);
      inset-inline-start: 50%;
      translate: -50% 0;
      z-index: 2;
      @include backdrop;
    }
    &__control {
      @include label;
      background: none;
      color: var(--foreground);
      &:disabled {
        opacity: 0.3;
        pointer-events: none;
      }
    }
  }
</style>
