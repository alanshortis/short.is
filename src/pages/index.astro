---
import { getCollection } from 'astro:content';
import Base from '../layouts/base.astro';
import { Circles, PostBox, ReadingList } from '../components';

const S3 = import.meta.env.S3;
const RECENT_WRITING_COUNT = 4;
const collection = await getCollection('posts');
const latestPosts = collection
  .filter(post => post.data.published ?? true)
  .sort((a, b) => b.data.pubDate.localeCompare(a.data.pubDate))
  .slice(0, RECENT_WRITING_COUNT);
---

<Base pageTitle="Alan Shortis" description="Alan Shortis. Web Engineer and occasional photo taker">
  <Circles slot="fixed" className="home__circles" />
  <div class="home">
    <div class="home__header">
      <h1 class="home__title">Alan Shortis&mdash;reading, writing, and photography</h1>
      <img
        src={`${S3}20250524-090210-2x.avif`}
        srcset={`${S3}20250524-090210-2x.avif 4x, ${S3}20250524-090210-2x.avif 1x`}
        class="home__photo"
        alt=""
        loading="lazy"
      />
    </div>
    <section>
      <div class="home__posts">
        {latestPosts.map((post, idx) => <PostBox post={post} />)}
      </div>
      <a href="/writing" class="home__link">More writing &rarr;</a>
    </section>
    <ReadingList />
  </div>
</Base>

<style lang="scss">
  @use '../styles/mixins' as *;

  .home {
    &__header {
      position: relative;
      display: flex;
      gap: var(--space);
      @include medium {
        flex-direction: column;
      }
    }
    &__photo {
      aspect-ratio: 2 / 3;
      border-radius: var(--radius);
      flex: 1;
      @include medium {
        @include full-bleed;
        max-width: none;
      }
    }
    display: flex;
    flex-direction: column;
    gap: calc(var(--step-5) * 2);
    &__title {
      flex: 1;
      font-size: var(--step-2);
      font-weight: bold;
      line-height: 1.305;
      margin-block-end: var(--step-5);
      text-wrap: balance;
    }
    &__posts {
      display: grid;
      gap: var(--space);
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 1fr;
      @include small {
        grid-template-columns: 1fr;
      }
    }
    &__link {
      display: inline-block;
      margin-block-start: var(--space--large);
      @include label;
    }
  }
  :global(.home__circles) {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    mix-blend-mode: lighten;
    html[data-scheme='light'] & {
      mix-blend-mode: darken;
    }
  }
</style>
