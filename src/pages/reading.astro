---
import Base from '../layouts/base.astro';
import { getCollection } from 'astro:content';

const [{ data }] = await getCollection('reading');
const items = data.items;
---

<Base
  pageTitle="Alan Shortis | Reading"
  description="Things of note I have recently read, watched, or listened to"
>
  <section class="post" aria-labelledby="reading">
    <h1 id="reading" class="vh">Reading</h1>
    <div class="list">
      {
        items.map((item, idx) => (
          <article>
            <a
              class={`list__item ${idx === 0 ? 'list__item--first' : ''}`}
              href={item.slug}
              target="_blank"
              rel="noopener noreferrer"
            >
              <h1 class="list__title">{item.title}</h1>
              <p class="list__author">{item.author}</p>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Base>

<style lang="scss">
  @use '../styles/mixins' as *;

  .post {
    display: flex;
    flex-direction: column;
    gap: var(--step-5);
  }

  .list {
    display: flex;
    flex-direction: column;
    &__item {
      align-items: flex-end;
      border-block-start: 1px solid var(--divider);
      display: flex;
      flex-wrap: wrap;
      gap: var(--space);
      padding-block: 1lh;
      text-wrap: pretty;
      &--first {
        border-block-start: none;
      }
    }
    &__author {
      font-size: var(--step--1);
      margin-inline-start: auto;
    }
    &__title {
      text-wrap: balance;
      line-height: 1.305;
    }
  }
</style>
